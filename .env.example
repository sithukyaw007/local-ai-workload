# Copy to .env and adjust values for your machine and models.

# Shared ports
GATEWAY_PORT=4000
LLAMA_SERVER_PORT=8080
OLLAMA_PORT=11434
OPEN_WEBUI_PORT=3000

# Gateway auth
LITELLM_MASTER_KEY=local-ai-workload
CLAUDE_API_KEYCHAIN_SERVICE=local-ai-workload-gateway-key

# llama.cpp model and runtime settings
LLAMA_MODEL_PATH=
# Recommended brew PATH flow: use Hugging Face model with explicit file.
LLAMA_HF_REPO=bartowski/Qwen2.5-Coder-7B-Instruct-GGUF
LLAMA_HF_FILE=Qwen2.5-Coder-7B-Instruct-Q4_K_M.gguf
LLAMA_ALIAS=local-coder-quality
LLAMA_CTX=32768
LLAMA_THREADS=8
LLAMA_GPU_LAYERS=999
LLAMA_BATCH=1024
LLAMA_UBATCH=512

# Optional model aliases exposed by gateway
MODEL_FAST=ollama/qwen2.5-coder:7b-instruct-q4_K_M
MODEL_QUALITY=llama_cpp/local-coder-quality
MODEL_GENERAL=ollama/qwen2.5:14b-instruct-q4_K_M

# Optional cloud fallback (disabled by default)
ENABLE_CLOUD_FALLBACK=false
CLOUD_MODEL=gpt-4.1-mini
CLOUD_API_KEY=
CLOUD_API_BASE=https://api.openai.com/v1

# Claude operating mode flags
CLAUDE_OFFLINE_MODE=true
CLAUDE_DEFAULT_MODEL=local-coder-quality

# Safety budgets for 64 GB RAM with 24 GB reserved
MAX_AI_MEMORY_GB=36
MAX_HEAVY_MODELS=1
DEFAULT_CONTEXT_WINDOW=12288
