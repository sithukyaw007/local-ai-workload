# Copy to .env and adjust values for your machine and models.

# Shared ports
GATEWAY_PORT=4000
MLX_SERVER_PORT=8000

# Gateway auth
LITELLM_MASTER_KEY=local-ai-workload
CLAUDE_API_KEYCHAIN_SERVICE=local-ai-workload-gateway-key

# MLX-LM model (served by mlx_lm.server)
MLX_MODEL=mlx-community/Qwen3.5-35B-A3B-4bit
MLX_SERVER_PATH=/Users/sithukyaw/work/local-mac-ai
# Log level: DEBUG (request/response payloads) | INFO (progress only)
MLX_LOG_LEVEL=DEBUG

# Model aliases exposed by gateway (all route to MLX)
MODEL_CODER=openai/mlx-community/Qwen3.5-35B-A3B-4bit
MODEL_GENERAL=openai/mlx-community/Qwen3.5-35B-A3B-4bit

# Optional cloud fallback (disabled by default)
ENABLE_CLOUD_FALLBACK=false
CLOUD_MODEL=gpt-4.1-mini
CLOUD_API_KEY=
CLOUD_API_BASE=https://api.openai.com/v1

# Claude operating mode flags
CLAUDE_OFFLINE_MODE=true
CLAUDE_DEFAULT_MODEL=local-coder-quality

# Safety budgets for 64 GB RAM with ~20 GB reserved for model
MAX_AI_MEMORY_GB=40
MAX_HEAVY_MODELS=1
DEFAULT_CONTEXT_WINDOW=16384
