# Copy to .env and adjust values as needed
# cp .env.example .env

# Runtime
LLAMA_SERVER_PORT=8080
LLAMA_SERVER_HOST=127.0.0.1
LLAMA_CTX_SIZE=4096
LLAMA_GPU_LAYERS=999

# Pick exactly one model source:
# 1) Local GGUF file path
LLAMA_MODEL_PATH=

# 2) Hugging Face repo + quant (used when LLAMA_MODEL_PATH is empty)
LLAMA_HF_REPO=bartowski/Qwen2.5-0.5B-Instruct-GGUF:Q4_K_M

# Optional extra args passed to llama-cli and llama-server
LLAMA_EXTRA_ARGS=
